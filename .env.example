# Copy to .env.local (never commit .env.local).
# Supabase: Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional (if your dashboard shows a publishable key)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Edge Functions used by the app: admin-snapshot, predict-reminders
# Deploy: npx supabase functions deploy admin-snapshot predict-reminders --project-ref YOUR_PROJECT_REF

# DB schema + seed: run supabase/one_shot_apply.sql in SQL Editor, or: npx supabase db push
